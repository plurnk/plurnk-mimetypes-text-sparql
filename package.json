{
    "name": "@plurnk/plurnk-mimetypes-text-sparql",
    "version": "0.3.1",
    "description": "application/sparql-query mimetype handler for plurnk-service. ANTLR-backed extraction via grammars-v4.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "application/sparql-query",
                "glyph": "🔍",
                "extensions": [
                    ".sparql",
                    ".rq"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "grammar/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:grammar": "plurnk-mimetypes-compile",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:grammar && npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "antlr4ng": "^3.0.0"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "antlr-ng": "^1.0.10",
        "typescript": "^6.0.3",
        "@plurnk/plurnk-mimetypes": "0.15.25"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.18"
    }
}
